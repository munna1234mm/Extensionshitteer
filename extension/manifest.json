{
    "manifest_version":  3,
    "name":  "Nexvora",
    "version":  "1.0.2",
    "description":  "The next generation of automation",
    "permissions":  [
                        "storage",
                        "activeTab",
                        "scripting",
                        "declarativeNetRequest",
                        "declarativeNetRequestWithHostAccess",
                        "offscreen",
                        "downloads",
                        "clipboardWrite",
                        "tabs",
                        "webNavigation",
                        "alarms",
                        "proxy",
                        "webRequest",
                        "webRequestAuthProvider",
                        "browsingData"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "background":  {
                       "service_worker":  "script/background.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "<all_urls>",
                                                "*://hitter.bypixel.site/*",
                                                "*://*.bypixel.site/*"
                                            ],
                                "js":  [
                                           "script/content.js",
                                           "script/bypass_checkout.js"
                                       ],
                                "css":  [
                                            "styles.css"
                                        ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "*://*.hcaptcha.com/*",
                                                "*://hcaptcha.com/*",
                                                "*://newassets.hcaptcha.com/*"
                                            ],
                                "js":  [
                                           "script/hcaptcha.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            }
                        ],
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "script/inject.js",
                                                           "script/storage.js",
                                                           "script/autofill.js",
                                                           "script/proxyhandler.js",
                                                           "script/binlibrary.js",
                                                           "script/countrylist.json",
                                                           "script/countrylist.js",
                                                           "styles.css",
                                                           "sounds/hit.wav",
                                                           "sounds/music.mp3",
                                                           "icons/icon128.png",
                                                           "fonts/SpaceGrotesk-Light.woff2",
                                                           "fonts/SpaceGrotesk-Regular.woff2",
                                                           "fonts/SpaceGrotesk-Medium.woff2",
                                                           "fonts/SpaceGrotesk-SemiBold.woff2",
                                                           "fonts/SpaceGrotesk-Bold.woff2"
                                                       ],
                                         "matches":  [
                                                         "\u003call_urls\u003e"
                                                     ]
                                     }
                                 ],
    "declarative_net_request":  {
                                    "rule_resources":  [
                                                           {
                                                               "id":  "ruleset_1",
                                                               "enabled":  true,
                                                               "path":  "rules.json"
                                                           }
                                                       ]
                                },
    "action":  {
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    },
                   "default_title":  "Nexvora Dashboard"
               },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              }
}

